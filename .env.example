# Seoul open-data API key — used by the api/ POI-fetch scripts (data.go.kr / B553766)
SEOUL_API_KEY=your_seoul_open_data_service_key

# Kakao REST API key — used by the webapp for geocoding (developers.kakao.com)
KAKAO_REST_API_KEY=your_kakao_rest_api_key

# Valhalla routing service URL (used by the webapp)
VALHALLA_URL=http://valhalla:8002
